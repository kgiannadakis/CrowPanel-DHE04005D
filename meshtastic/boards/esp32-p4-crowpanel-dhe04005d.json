{
  "build": {
    "arduino": {
      "ldscript": "esp32p4_out.ld",
      "memory_type": "qio_psram",
      "partitions": "partitions.csv"
    },
    "core": "esp32",
    "extra_flags": [
      "-DARDUINO_ESP32P4_DEV",
      "-DARDUINO_USB_CDC_ON_BOOT=0",
      "-DBOARD_HAS_PSRAM",
      "-DCONFIG_IDF_TARGET_ESP32P4=1"
    ],
    "f_cpu": "360000000L",
    "f_flash": "80000000L",
    "flash_mode": "qio",
    "hwids": [["0x303A", "0x1001"]],
    "mcu": "esp32p4",
    "variant": "esp32p4"
  },
  "connectivity": ["wifi", "lora"],
  "debug": {
    "default_tool": "esp-builtin",
    "onboard_tools": ["esp-builtin"],
    "openocd_target": "esp32p4.cfg"
  },
  "frameworks": ["arduino", "espidf"],
  "name": "CrowPanel DHE04005D (ESP32-P4 + 5\" 800x480 RGB)",
  "upload": {
    "flash_size": "16MB",
    "maximum_ram_size": 786432,
    "maximum_size": 16777216,
    "require_upload_port": true,
    "speed": 921600
  },
  "monitor": {
    "speed": 115200
  },
  "url": "https://www.elecrow.com/crowpanel-advance-5-0-inch-hmi-esp32-display.html",
  "vendor": "Elecrow"
}
